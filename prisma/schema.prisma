// ShiftSwapper schema per docs/backend.md
// Use PostgreSQL in production; for local dev set DATABASE_URL to a local Postgres or use SQLite by changing provider.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  email         String    @unique
  passwordHash  String    @map("password_hash")
  phone         String?
  position      String    // e.g. Pharmacist; validated against ROLES
  role          String    @default("member") // member | admin
  smsConsent    Boolean   @default(false) @map("sms_consent")
  smsConsentAt  DateTime? @map("sms_consent_at")
  emailVerified Boolean   @default(false) @map("email_verified")
  phoneVerified Boolean   @default(false) @map("phone_verified")
  emailVerificationToken   String?   @map("email_verification_token")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  phoneVerificationCode    String?   @map("phone_verification_code")
  phoneVerificationExpiresAt DateTime? @map("phone_verification_expires_at")
  passwordResetToken       String?   @map("password_reset_token")
  passwordResetExpiresAt   DateTime? @map("password_reset_expires_at")
  passwordResetMethod      String?   @map("password_reset_method")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  shiftsPosted  Shift[]   @relation("PostedBy")

  @@map("users")
}

model Shift {
  id               String    @id @default(uuid())
  posterName       String    @map("poster_name")
  posterEmail      String    @map("poster_email")
  posterPhone      String?   @map("poster_phone")
  location         String
  role             String
  shiftDate        DateTime  @db.Date @map("shift_date")
  startTime        String    @map("start_time") // HH:MM
  endTime          String    @map("end_time")   // HH:MM
  status           String    @default("open")   // open | covered | cancelled
  covererName      String?   @map("coverer_name")
  covererEmail     String?   @map("coverer_email")
  covererPhone     String?   @map("coverer_phone")
  postedByUserId   String?   @map("posted_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  coveredAt        DateTime? @map("covered_at")

  postedByUser User? @relation("PostedBy", fields: [postedByUserId], references: [id], onDelete: SetNull)

  @@map("shifts")
}

model Settings {
  id              String   @id @default(uuid())
  schedulerEmail   String   @map("scheduler_email")
  timezone         String   @default("America/Chicago")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
