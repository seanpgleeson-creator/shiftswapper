# Database (PostgreSQL). For local dev use a local Postgres URL or a hosted one (Neon, Supabase, Vercel Postgres).
DATABASE_URL="postgresql://user:password@localhost:5432/shiftswapper?schema=public"

# Email (Resend). Required when covering shifts.
# RESEND_API_KEY="re_..."
# Optional: from address (default Resend onboarding domain)
# RESEND_FROM="ShiftSwap <notifications@yourdomain.com>"

# Scheduler email can be set in DB seed; override via env for notifications if needed.
# SCHEDULER_EMAIL="scheduler@example.com"

# SMS (Twilio). Optional; when set, poster receives SMS on cover with coverer name and UKG prompt.
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_PHONE_NUMBER="+15551234567"

# NextAuth (required for sign-up / login). Generate with: openssl rand -base64 32
# NEXTAUTH_SECRET="..."
# Optional: base URL for auth callbacks (defaults to NEXT_PUBLIC_VERCEL_URL or http://localhost:3000)
# NEXTAUTH_URL="http://localhost:3000"

# Sentry (error tracking). DSN is safe to expose client-side; auth token is for source map uploads only.
# NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
# SENTRY_AUTH_TOKEN="sntrys_..."
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="your-project"
